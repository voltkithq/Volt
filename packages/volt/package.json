{
  "name": "voltkit",
  "version": "0.1.4",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/voltkithq/Volt"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./dist/renderer.js"
    },
    "./ipc-contract": {
      "types": "./dist/ipc-contract.d.ts",
      "default": "./dist/ipc-contract.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "default": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.{ts,mts,cts}\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@voltkit/volt-native": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
