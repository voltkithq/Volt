{
  "name": "@voltkit/create-volt",
  "version": "0.1.9",
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/voltkithq/Volt"
  },
  "description": "Create a new Volt desktop application",
  "bin": {
    "create-volt": "dist/index.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "lint": "eslint \"src/**/*.{ts,mts,cts,js,mjs,cjs}\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/prompts": "^2.4.9",
    "@types/node": "^25.2.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">= 20"
  }
}
